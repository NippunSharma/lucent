# Google Cloud / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Manim Cloud Run renderer
MANIM_RENDER_BACKEND=cloudrun
MANIMGL_CLOUDRUN_URL=https://your-manimgl-renderer-url.run.app

# Optional: Google AI Studio key (for image generation)
# GOOGLE_AI_STUDIO_API_KEY=your-api-key
